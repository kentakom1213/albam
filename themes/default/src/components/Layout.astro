---
import "../styles/global.css";

type Props = {
  title?: string;
};

const { title = "Albam" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">Albam</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Albums</a>
        <a href="/tags">Tags</a>
        <a href="/search">Search</a>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>
  </body>
</html>
