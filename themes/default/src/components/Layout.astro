---
import "../styles/theme.css";
import "../styles/global.css";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import { getThemeConfig } from "../lib/theme-config";

type Props = {
  title?: string;
};

const { title = "albam" } = Astro.props;
const theme = getThemeConfig();
const accentStyle = `--theme-current-accent: ${theme.accent.color}; --theme-current-accent-soft: ${theme.accent.soft};`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/theme/runtime.css" />
    <title>{title}</title>
  </head>
  <body style={accentStyle}>
    {theme.features.showHeader && <Header />}
    <slot />
    {theme.features.showFooter && <Footer />}
  </body>
</html>
