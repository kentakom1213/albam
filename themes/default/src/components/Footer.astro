---
import { getThemeConfig } from "../lib/theme-config";

const theme = getThemeConfig();
const hasCopyright = theme.footer.copyright !== "";
const hasText = theme.footer.text !== "";
const hasAnyText = hasCopyright || hasText;
---

<footer class="site-footer">
  <span data-theme-footer-copyright hidden={!hasCopyright}>{theme.footer.copyright}</span>
  <span class="footer-separator" data-theme-footer-content-separator aria-hidden="true" hidden={!(hasCopyright && hasText)}>|</span>
  <span data-theme-footer-text hidden={!hasText}>{theme.footer.text}</span>
  <span class="footer-separator" data-theme-footer-powered-separator aria-hidden="true" hidden={!hasAnyText}>|</span>
  <span>
    Powered by{" "}
    <a href="https://github.com/kentakom1213/albam" rel="noreferrer" target="_blank">
      albam
    </a>
  </span>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 40px 24px 32px;
    color: var(--theme-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .site-footer a {
    color: var(--theme-text);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--theme-current-accent);
    text-underline-offset: 3px;
  }

  .footer-separator {
    color: var(--theme-border);
  }
</style>
