---
import Layout from "../../components/Layout.astro";
import { formatPageTitle, getThemeConfig, siteTitlePrefix } from "../../lib/theme-config";

const theme = getThemeConfig();
const titlePrefix = siteTitlePrefix(theme);
---

<Layout title={formatPageTitle(titlePrefix, "Album")}>
  <main
    class="page-shell detail-page"
    data-site-title={titlePrefix}
  >
    <div class="detail-topbar">
      <nav class="breadcrumb" id="album-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Albums</a>
        <span class="separator" aria-hidden="true">/</span>
        <span aria-current="page">Loading</span>
      </nav>

      <div class="toolbar-chips" aria-label="Photo filters">
        <button class="chip small" type="button" data-photo-sort="taken_at_desc">Newest</button>
        <button class="chip active small" type="button" data-photo-sort="taken_at_asc">Oldest</button>
        <button class="help-button" type="button" aria-label="Album info" aria-expanded="false">?</button>
      </div>
    </div>

    <section class="album-hero" aria-labelledby="album-title">
      <div class="hero-content">
        <h1 id="album-title" class="page-title">Loading</h1>
        <p class="lead" id="album-description"></p>
      </div>
    </section>

    <div class="album-controls">
      <div class="meta-chips" id="meta-chips" aria-label="Album metadata"></div>
    </div>

    <section class="photos-section" aria-label="Photos">
      <div class="photo-grid" id="photo-grid">
        <div class="photo-card loading-photo-card" aria-label="Loading photos">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
      </div>

      <div class="pagination-actions">
        <button class="button" id="load-more-photos" type="button" hidden>Load more</button>
      </div>
    </section>

    <div class="photo-modal" id="photo-modal" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
      <button class="modal-backdrop" type="button" data-modal-close aria-label="Close photo viewer"></button>
      <figure class="modal-frame">
        <button class="modal-close" type="button" data-modal-close aria-label="Close photo viewer"></button>
        <div class="modal-loading" aria-hidden="true">
          <span class="modal-loading-ring"></span>
        </div>
        <img id="modal-image" alt="" />
        <figcaption id="modal-caption"></figcaption>
      </figure>
    </div>

    <aside class="album-info-modal" id="album-info-modal" role="dialog" aria-label="Album info" hidden>
      <h2>Album info</h2>
      <dl>
        <div>
          <dt>Photos</dt>
          <dd id="info-photos">-</dd>
        </div>
        <div>
          <dt>Size</dt>
          <dd id="info-size">-</dd>
        </div>
        <div>
          <dt>Created</dt>
          <dd id="info-created">-</dd>
        </div>
        <div>
          <dt>Updated</dt>
          <dd id="info-updated">-</dd>
        </div>
      </dl>
    </aside>
  </main>
</Layout>

<script>
  import { formatCompactDate, formatCompactMonth, getAlbum, getAlbumPhotosWithPagination, getApiConfig, getPhoto } from "../../lib/api";
  import type { Album, Breadcrumb, Photo, PhotoSort } from "../../lib/api";
  import { buildFixedRowLayout } from "../../lib/fixedRowLayout";
  import { applyRuntimeContent, titlePrefix } from "../../lib/runtime-content";

  const tones = ["peach", "linen", "mint", "sky", "lilac", "lemon"] as const;
  let siteTitle =
    document.querySelector<HTMLElement>(".detail-page")?.dataset.siteTitle ?? "albam";
  const photoGrid = document.querySelector<HTMLElement>("#photo-grid");
  const photoModal = document.querySelector<HTMLElement>("#photo-modal");
  const modalImage = document.querySelector<HTMLImageElement>("#modal-image");
  const modalCaption = document.querySelector<HTMLElement>("#modal-caption");
  const albumInfoModal = document.querySelector<HTMLElement>("#album-info-modal");
  const helpButton = document.querySelector<HTMLButtonElement>(".help-button");
  const loadMorePhotosButton = document.querySelector<HTMLButtonElement>("#load-more-photos");
  let enableOriginalDownload = false;
  let renderedPhotos: Photo[] = [];
  let loadedPhotoCount = 0;
  let hasMorePhotos = false;
  let currentPhotoSort: PhotoSort = "taken_at_asc";

  function escapeHTML(value: string) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return entities[char];
    });
  }

  function currentAlbumId() {
    const parts = window.location.pathname.split("/").filter(Boolean);
    return parts[0] === "albums" ? decodeURIComponent(parts[1] ?? "") : "";
  }

  function currentPhotoId() {
    const parts = window.location.pathname.split("/").filter(Boolean);
    return parts[0] === "albums" && parts[2] === "media" ? decodeURIComponent(parts[3] ?? "") : "";
  }

  function albumPath(albumId: string) {
    return `/albums/${encodeURIComponent(albumId)}/`;
  }

  function photoPath(albumId: string, photoId: string) {
    return `${albumPath(albumId)}media/${encodeURIComponent(photoId)}/`;
  }

  function imageHTML(src: string | undefined, tone: Album["tone"], alt: string, collage = false) {
    if (src) {
      return `<img class="image" src="${escapeHTML(src)}" alt="${escapeHTML(alt)}" loading="lazy" />`;
    }

    return `
      <div class="placeholder ${tone ?? "peach"} ${collage ? "collage" : ""}" role="img" aria-label="${escapeHTML(alt)}">
        <span class="circle-large"></span>
        <span class="circle-corner"></span>
        <span class="accent-mark"></span>
        <span class="soft-square"></span>
        <span class="stripe stripe-one"></span>
        <span class="stripe stripe-two"></span>
      </div>
    `;
  }

  function photoCard(photo: Photo, index: number) {
    const tone = photo.tone ?? tones[index % tones.length];
    const originalSrc = photo.originalSrc ?? photo.previewSrc ?? photo.src ?? "";

    return `
      <button
        class="photo-card"
        type="button"
        data-photo-id="${escapeHTML(photo.id)}"
        data-original-src="${escapeHTML(originalSrc)}"
        data-preview-src="${escapeHTML(photo.previewSrc ?? photo.src ?? "")}"
        data-title="${escapeHTML(photo.title)}"
      >
        <div class="photo-image">
          ${imageHTML(photo.src, tone, photo.title)}
        </div>
      </button>
    `;
  }

  function modalSrc(originalSrc: string, previewSrc: string) {
    return enableOriginalDownload ? originalSrc || previewSrc : previewSrc || originalSrc;
  }

  function layoutOptions(width: number) {
    if (width < 560) {
      return {
        containerWidth: width,
        gap: 8,
        rowHeight: 150,
        minTileWidth: 132,
        maxTileWidth: 320,
        minScale: 0.82,
        maxScale: 1.18,
        maxItemsPerRow: 3,
        justifyLastRow: false,
      };
    }

    if (width < 960) {
      return {
        containerWidth: width,
        gap: 10,
        rowHeight: 196,
        minTileWidth: 150,
        maxTileWidth: 430,
        minScale: 0.82,
        maxScale: 1.18,
        maxItemsPerRow: 5,
        justifyLastRow: false,
      };
    }

    return {
      containerWidth: width,
      gap: 10,
      rowHeight: 205,
      minTileWidth: 145,
      maxTileWidth: 560,
      minScale: 0.82,
      maxScale: 1.18,
      maxItemsPerRow: 6,
      justifyLastRow: false,
    };
  }

  function applyPhotoLayout() {
    if (!photoGrid || renderedPhotos.length === 0) {
      return;
    }

    const containerWidth = photoGrid.clientWidth;
    const layout = buildFixedRowLayout(
      renderedPhotos.map((photo) => ({
        id: photo.id,
        width: photo.width,
        height: photo.height,
        aspectRatio: photo.aspectRatio,
      })),
      layoutOptions(containerWidth),
    );
    const itemsById = new Map(layout.items.map((item) => [item.id, item]));

    photoGrid.style.height = `${Math.ceil(layout.height)}px`;

    for (const card of photoGrid.querySelectorAll<HTMLElement>(".photo-card")) {
      const item = itemsById.get(card.dataset.photoId ?? "");

      if (!item) {
        continue;
      }

      card.style.transform = `translate(${formatLayoutPixel(item.x)}, ${formatLayoutPixel(item.y)})`;
      card.style.width = formatLayoutPixel(item.width);
      card.style.height = formatLayoutPixel(item.height);
    }
  }

  function formatLayoutPixel(value: number) {
    return `${Number(value.toFixed(3))}px`;
  }

  function setText(selector: string, value: string) {
    const element = document.querySelector<HTMLElement>(selector);
    if (element) {
      element.textContent = value;
    }
  }

  function breadcrumbItemHTML(item: Breadcrumb, isCurrent: boolean) {
    const title = escapeHTML(item.title);

    if (isCurrent) {
      return `<span aria-current="page">${title}</span>`;
    }

    return `<a href="${escapeHTML(item.href)}">${title}</a>`;
  }

  function renderBreadcrumbs(album: Album) {
    const breadcrumbs = document.querySelector<HTMLElement>("#album-breadcrumbs");
    if (!breadcrumbs) {
      return;
    }

    const items = album.breadcrumbs.length
      ? album.breadcrumbs
      : [{ id: album.id, title: album.title, path: album.id, href: `/albums/${album.id}/` }];

    breadcrumbs.innerHTML = [
      `<a href="/">Albums</a>`,
      ...items.flatMap((item, index) => [
        `<span class="separator" aria-hidden="true">/</span>`,
        breadcrumbItemHTML(item, index === items.length - 1),
      ]),
    ].join("");
  }

  function renderAlbumInfo(album: Album, totalPhotos: number) {
    setText("#info-photos", totalPhotos.toLocaleString("en-US"));
    setText("#info-size", album.size);
    setText("#info-created", album.createdAt);
    setText("#info-updated", album.updatedAt);
  }

  function setActivePhotoSort(sort: PhotoSort) {
    currentPhotoSort = sort;
    document.querySelectorAll<HTMLElement>("[data-photo-sort]").forEach((button) => {
      button.classList.toggle("active", button.dataset.photoSort === sort);
    });
  }

  async function renderAlbum() {
    const albumId = currentAlbumId();

    if (!albumId || !photoGrid) {
      if (photoGrid) {
        photoGrid.innerHTML = `<p class="load-state">Album not found.</p>`;
      }
      return;
    }

    try {
      const [album, photosResult, apiConfig] = await Promise.all([
        getAlbum(albumId),
        getAlbumPhotosWithPagination(albumId, { sort: currentPhotoSort }),
        getApiConfig(),
      ]);
      const { photos, pagination } = photosResult;
      enableOriginalDownload = apiConfig.enableOriginalDownload;
      loadedPhotoCount = photos.length;
      hasMorePhotos = pagination.has_next;
      const visibleDate = formatCompactDate(album.date ?? album.newestTakenAt ?? album.createdAt);
      const shortDate = formatCompactMonth(album.date ?? album.newestTakenAt ?? album.createdAt);

      document.title = [siteTitle, album.title].filter((part) => part !== "").join(" | ");
      renderBreadcrumbs(album);
      renderAlbumInfo(album, pagination.total);
      setText("#album-title", album.title);
      setText("#album-description", album.description);

      const metaChips = document.querySelector<HTMLElement>("#meta-chips");

      if (metaChips) {
        metaChips.style.setProperty("--short-date", `"${shortDate}"`);
        metaChips.innerHTML = `
          <span class="chip active">${pagination.total.toLocaleString("en-US")} photos</span>
          <span class="chip">${escapeHTML(visibleDate)}</span>
        `;
      }

      renderedPhotos = photos;
      photoGrid.classList.toggle("is-empty", photos.length === 0);
      photoGrid.removeAttribute("style");
      photoGrid.innerHTML = photos.length
        ? photos.map(photoCard).join("")
        : `<p class="load-state">No photos indexed yet.</p>`;
      applyPhotoLayout();
      updateLoadMorePhotosButton();

      openDirectLinkedPhoto();
    } catch (error) {
      console.error(error);
      renderedPhotos = [];
      photoGrid.classList.add("is-empty");
      photoGrid.removeAttribute("style");
      photoGrid.innerHTML = `<p class="load-state">Failed to load album.</p>`;
    }
  }

  function openPhotoModal(src: string, fallbackSrc: string, title: string, photoId = "", updateURL = false) {
    if (!photoModal || !modalImage || !modalCaption || !src) {
      return;
    }

    if (updateURL && photoId) {
      const albumId = currentAlbumId();
      if (albumId) {
        window.history.pushState({ photoId }, "", photoPath(albumId, photoId));
      }
    }

    photoModal.classList.add("is-loading");
    modalImage.src = src;
    modalImage.alt = title;
    modalImage.dataset.fallbackSrc = fallbackSrc;
    modalCaption.textContent = title;
    photoModal.hidden = false;
    document.body.classList.add("modal-open");
  }

  function closePhotoModal(updateURL = true) {
    if (!photoModal || !modalImage || !modalCaption) {
      return;
    }

    if (updateURL && currentPhotoId()) {
      const albumId = currentAlbumId();
      if (albumId) {
        window.history.pushState({}, "", albumPath(albumId));
      }
    }

    photoModal.hidden = true;
    photoModal.classList.remove("is-loading");
    modalImage.removeAttribute("src");
    modalImage.removeAttribute("data-fallback-src");
    modalImage.alt = "";
    modalCaption.textContent = "";
    document.body.classList.remove("modal-open");
  }

  function openAlbumInfoModal() {
    if (!albumInfoModal || !helpButton) {
      return;
    }

    albumInfoModal.hidden = false;
    helpButton.setAttribute("aria-expanded", "true");
  }

  function closeAlbumInfoModal() {
    if (!albumInfoModal || !helpButton) {
      return;
    }

    albumInfoModal.hidden = true;
    helpButton.setAttribute("aria-expanded", "false");
  }

  function toggleAlbumInfoModal() {
    if (!albumInfoModal || albumInfoModal.hidden) {
      openAlbumInfoModal();
      return;
    }

    closeAlbumInfoModal();
  }

  function updateLoadMorePhotosButton() {
    if (!loadMorePhotosButton) {
      return;
    }

    loadMorePhotosButton.hidden = !hasMorePhotos;
    loadMorePhotosButton.disabled = false;
    loadMorePhotosButton.textContent = "Load more";
  }

  function loadingButtonHTML(label: string) {
    return `
      <span>${label}</span>
      <span class="button-loading-dots" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    `;
  }

  async function loadMorePhotos() {
    const albumId = currentAlbumId();
    if (!albumId || !photoGrid || !loadMorePhotosButton || !hasMorePhotos) {
      return;
    }

    loadMorePhotosButton.disabled = true;
    loadMorePhotosButton.innerHTML = loadingButtonHTML("Loading");

    try {
      const { photos, pagination } = await getAlbumPhotosWithPagination(albumId, {
        offset: loadedPhotoCount,
        sort: currentPhotoSort,
      });
      renderedPhotos = [...renderedPhotos, ...photos];
      photoGrid.insertAdjacentHTML("beforeend", photos.map((photo, index) => photoCard(photo, loadedPhotoCount + index)).join(""));
      loadedPhotoCount += photos.length;
      hasMorePhotos = pagination.has_next;
      applyPhotoLayout();
      updateLoadMorePhotosButton();
    } catch (error) {
      console.error(error);
      loadMorePhotosButton.disabled = false;
      loadMorePhotosButton.textContent = "Load more";
    }
  }

  async function reloadPhotos(sort: PhotoSort) {
    const albumId = currentAlbumId();
    if (!albumId || !photoGrid) {
      return;
    }

    setActivePhotoSort(sort);
    loadedPhotoCount = 0;
    hasMorePhotos = false;
    photoGrid.classList.remove("is-empty");
    photoGrid.removeAttribute("style");
    photoGrid.innerHTML = `
      <div class="photo-card loading-photo-card" aria-label="Loading photos">
        <div class="photo-image loading-image">
          <span class="loading-circle large"></span>
          <span class="loading-circle small"></span>
          <span class="loading-mark"></span>
        </div>
      </div>
    `;
    updateLoadMorePhotosButton();

    try {
      const { photos, pagination } = await getAlbumPhotosWithPagination(albumId, { sort });
      renderedPhotos = photos;
      loadedPhotoCount = photos.length;
      hasMorePhotos = pagination.has_next;
      photoGrid.classList.toggle("is-empty", photos.length === 0);
      photoGrid.removeAttribute("style");
      photoGrid.innerHTML = photos.length
        ? photos.map(photoCard).join("")
        : `<p class="load-state">No photos indexed yet.</p>`;
      applyPhotoLayout();
      updateLoadMorePhotosButton();
    } catch (error) {
      console.error(error);
      renderedPhotos = [];
      photoGrid.classList.add("is-empty");
      photoGrid.removeAttribute("style");
      photoGrid.innerHTML = `<p class="load-state">Failed to load photos.</p>`;
    }
  }

  async function openDirectLinkedPhoto() {
    const photoId = currentPhotoId();
    if (!photoId) {
      return;
    }

    try {
      const photo = await getPhoto(photoId);
      const previewSrc = photo.previewSrc ?? photo.src ?? "";
      const originalSrc = photo.originalSrc ?? previewSrc;
      openPhotoModal(
        modalSrc(originalSrc, previewSrc),
        previewSrc,
        photo.title,
      );
    } catch (error) {
      console.error(error);
    }
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    const closeButton = target.closest("[data-modal-close]");
    if (closeButton) {
      closePhotoModal();
      return;
    }

    const sortButton = target.closest<HTMLElement>("[data-photo-sort]");
    if (sortButton) {
      const sort = sortButton.dataset.photoSort;
      if (sort === "taken_at_desc" || sort === "taken_at_asc") {
        void reloadPhotos(sort);
      }
      return;
    }

    if (target.closest(".help-button")) {
      toggleAlbumInfoModal();
      return;
    }

    if (albumInfoModal && !albumInfoModal.hidden && !target.closest("#album-info-modal")) {
      closeAlbumInfoModal();
    }

    const photoCard = target.closest<HTMLElement>(".photo-card");
    if (!photoCard) {
      return;
    }

    const previewSrc = photoCard.dataset.previewSrc ?? "";
    const originalSrc = photoCard.dataset.originalSrc ?? previewSrc;

    openPhotoModal(
      modalSrc(originalSrc, previewSrc),
      previewSrc,
      photoCard.dataset.title ?? "Photo",
      photoCard.dataset.photoId ?? "",
      true,
    );
  });

  loadMorePhotosButton?.addEventListener("click", loadMorePhotos);

  window.addEventListener("popstate", () => {
    if (currentPhotoId()) {
      openDirectLinkedPhoto();
      return;
    }

    closePhotoModal(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && albumInfoModal && !albumInfoModal.hidden) {
      closeAlbumInfoModal();
    }

    if (event.key === "Escape" && photoModal && !photoModal.hidden) {
      closePhotoModal();
    }
  });

  modalImage?.addEventListener("error", () => {
    const fallbackSrc = modalImage.dataset.fallbackSrc;
    if (fallbackSrc && modalImage.src !== fallbackSrc) {
      modalImage.src = fallbackSrc;
      photoModal?.classList.add("is-loading");
      return;
    }

    photoModal?.classList.remove("is-loading");
  });

  modalImage?.addEventListener("load", () => {
    if (modalImage.currentSrc) {
      photoModal?.classList.remove("is-loading");
    }
  });

  const resizeObserver = new ResizeObserver(() => {
    applyPhotoLayout();
  });

  if (photoGrid) {
    resizeObserver.observe(photoGrid);
  }

  async function boot() {
    const content = await applyRuntimeContent({ page: "album" });
    siteTitle = titlePrefix(content, siteTitle);
    await renderAlbum();
  }

  void boot();
</script>

<style>
  .detail-page {
    padding: 48px 0 110px;
  }

  .detail-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    margin: 0;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--theme-text);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--theme-text);
  }

  .album-hero {
    display: block;
    gap: 34px;
    margin-bottom: 48px;
  }

  .hero-content {
    display: flex;
    align-items: baseline;
    gap: 36px;
    min-height: 0;
  }

  .hero-content .page-title {
    flex: 0 0 auto;
    margin: 0;
    font-size: clamp(54px, 5.6vw, 68px);
  }

  .hero-content .lead {
    max-width: 780px;
    color: var(--theme-muted);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.7;
  }

  .album-controls {
    display: none;
  }

  .meta-chips,
  .toolbar-chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .photo-grid {
    position: relative;
    width: 100%;
    min-height: 160px;
    overflow: visible;
  }

  .photo-grid:has(.loading-photo-card) {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 10px;
  }

  .load-state {
    margin: 0;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  :global(.button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 24px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 14px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.button.primary) {
    border-color: var(--theme-text);
    background: var(--theme-text);
    color: var(--theme-surface);
  }

  .pagination-actions {
    display: flex;
    justify-content: center;
    margin-top: 28px;
  }

  .pagination-actions:has([hidden]) {
    display: none;
  }

  .button[disabled] {
    cursor: progress;
    opacity: 0.78;
  }

  :global(.button-loading-dots) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 10px;
  }

  :global(.button-loading-dots span) {
    width: 5px;
    height: 5px;
    border-radius: var(--radius-pill);
    background: var(--theme-current-accent);
    animation: loading-dot 0.9s ease-in-out infinite;
  }

  :global(.button-loading-dots span:nth-child(2)) {
    animation-delay: 0.12s;
