---
import Header from "../../components/Header.astro";
import Layout from "../../components/Layout.astro";
import { getThemeConfig } from "../../lib/theme-config";

const theme = getThemeConfig();
---

<Layout title={`${theme.siteTitle} | Album`}>
  <Header />

  <main class="page-shell detail-page" data-site-title={theme.siteTitle}>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Albums</a>
      <span>/</span>
      <span id="breadcrumb-kind">Album</span>
      <strong id="breadcrumb-title">Loading</strong>
    </nav>

    <section class="album-hero" aria-labelledby="album-title">
      <div class="hero-content">
        <h1 id="album-title" class="page-title">Loading</h1>
        <p class="lead" id="album-description"></p>
        <div class="meta-chips" id="meta-chips" aria-label="Album metadata"></div>
      </div>

      <div class="actions">
        <button class="button primary" type="button">Share</button>
        <button class="help-button" type="button" aria-label="Help">?</button>
      </div>
    </section>

    <section class="photos-section" aria-labelledby="photos-title">
      <div class="photos-toolbar">
        <h2 id="photos-title">Photos</h2>
        <div class="toolbar-chips" aria-label="Photo filters">
          <span class="chip active small">All</span>
          <span class="chip small">Favorites</span>
          <span class="chip small">Newest</span>
        </div>
      </div>

      <div class="photo-grid" id="photo-grid">
        <p class="load-state">Loading photos...</p>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { formatCompactDate, formatCompactMonth, getAlbum, getAlbumPhotos } from "../../lib/api";
  import type { Album, Photo } from "../../lib/api";

  const tones = ["peach", "linen", "mint", "sky", "lilac", "lemon"] as const;
  const siteTitle =
    document.querySelector<HTMLElement>(".detail-page")?.dataset.siteTitle ?? "albam";

  function escapeHTML(value: string) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return entities[char];
    });
  }

  function currentAlbumId() {
    const parts = window.location.pathname.split("/").filter(Boolean);
    return parts[0] === "albums" ? decodeURIComponent(parts[1] ?? "") : "";
  }

  function imageHTML(src: string | undefined, tone: Album["tone"], alt: string, collage = false) {
    if (src) {
      return `<img class="image" src="${escapeHTML(src)}" alt="${escapeHTML(alt)}" loading="lazy" />`;
    }

    return `
      <div class="placeholder ${tone ?? "peach"} ${collage ? "collage" : ""}" role="img" aria-label="${escapeHTML(alt)}">
        <span class="circle-large"></span>
        <span class="circle-corner"></span>
        <span class="accent-mark"></span>
        <span class="soft-square"></span>
        <span class="stripe stripe-one"></span>
        <span class="stripe stripe-two"></span>
      </div>
    `;
  }

  function photoCard(photo: Photo, index: number) {
    const tone = photo.tone ?? tones[index % tones.length];
    const selected = index === 1;

    return `
      <article class="photo-card ${selected ? "selected" : ""}">
        <div class="photo-image">
          ${imageHTML(photo.src, tone, photo.title)}
        </div>
        <div class="photo-title">
          <span>${escapeHTML(photo.title)}</span>
          ${selected ? `<span class="dot" aria-hidden="true"></span>` : ""}
        </div>
      </article>
    `;
  }

  function setText(selector: string, value: string) {
    const element = document.querySelector<HTMLElement>(selector);
    if (element) {
      element.textContent = value;
    }
  }

  async function renderAlbum() {
    const albumId = currentAlbumId();
    const photoGrid = document.querySelector<HTMLElement>("#photo-grid");

    if (!albumId || !photoGrid) {
      if (photoGrid) {
        photoGrid.innerHTML = `<p class="load-state">Album not found.</p>`;
      }
      return;
    }

    try {
      const [album, photos] = await Promise.all([getAlbum(albumId), getAlbumPhotos(albumId)]);
      const visibleDate = formatCompactDate(album.createdAt);
      const shortDate = formatCompactMonth(album.createdAt);

      document.title = `${siteTitle} | ${album.title}`;
      setText("#breadcrumb-kind", album.kind.replace(" ALBUM", ""));
      setText("#breadcrumb-title", album.title);
      setText("#album-title", album.title);
      setText("#album-description", album.description);

      const metaChips = document.querySelector<HTMLElement>("#meta-chips");

      if (metaChips) {
        metaChips.style.setProperty("--short-date", `"${shortDate}"`);
        metaChips.innerHTML = `
          <span class="chip active">${album.photoCount.toLocaleString("en-US")} photos</span>
          <span class="chip">${escapeHTML(visibleDate)}</span>
        `;
      }

      photoGrid.innerHTML = photos.length
        ? photos.map(photoCard).join("")
        : `<p class="load-state">No photos indexed yet.</p>`;
    } catch (error) {
      console.error(error);
      photoGrid.innerHTML = `<p class="load-state">Failed to load album.</p>`;
    }
  }

  renderAlbum();
</script>

<style>
  .detail-page {
    padding: 44px 0 110px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 48px;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  .breadcrumb strong {
    color: var(--theme-text);
  }

  .album-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: end;
    margin-bottom: 74px;
  }

  .hero-content {
    min-height: 0;
  }

  .hero-content .page-title {
    display: inline-block;
    margin: 0 42px 0 0;
    font-size: clamp(52px, 5.8vw, 70px);
    vertical-align: middle;
  }

  .hero-content .lead {
    display: inline;
    color: var(--theme-muted);
    font-size: 23px;
    font-weight: 600;
    line-height: 1.7;
  }

  .meta-chips,
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .meta-chips {
    margin-top: 36px;
  }

  .actions {
    align-items: center;
    justify-content: flex-end;
    margin-bottom: 2px;
  }

  .photos-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 66px;
    margin-bottom: 34px;
    padding: 0 23px;
    border: 1px solid var(--theme-border);
    border-radius: 20px;
    background: var(--theme-surface);
  }

  .photos-toolbar h2 {
    margin: 0;
    color: var(--theme-text);
    font-size: 27px;
    font-weight: 900;
  }

  .toolbar-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 18px 54px;
  }

  .load-state {
    grid-column: 1 / -1;
    margin: 0;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  :global(.button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 24px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 14px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.button.primary) {
    border-color: var(--theme-text);
    background: var(--theme-text);
    color: var(--theme-surface);
  }

  .help-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
  }

  :global(.chip) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0 17px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-muted);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.chip.active) {
    border-color: var(--theme-current-accent);
    background: var(--theme-current-accent-soft);
    color: var(--theme-text);
  }

  :global(.chip.small) {
    min-height: 30px;
    padding: 0 14px;
    font-size: 13px;
  }

  :global(.image),
  :global(.placeholder) {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 12px;
  }

  :global(.image) {
    object-fit: cover;
  }

  :global(.placeholder) {
    position: relative;
    background: var(--ph-bg);
  }

  :global(.photo-card) {
    padding: 8px 8px 12px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-card);
    background: var(--theme-surface);
    overflow: hidden;
  }

  :global(.photo-card.selected) {
    border-color: var(--theme-current-accent);
    box-shadow: inset 0 0 0 1px var(--theme-current-accent);
  }

  :global(.photo-image) {
    aspect-ratio: 1;
  }

  :global(.photo-title) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    min-height: 39px;
    padding: 10px 2px 0;
    color: var(--theme-muted);
    font-size: 14px;
    font-weight: 500;
  }

  :global(.photo-title span:first-child) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.peach) {
    --ph-bg: #f9cdb9;
    --ph-circle: #fde6dc;
    --ph-corner: #f7a99e;
    --ph-square: #fff5ee;
    --ph-line: rgb(17 17 17 / 62%);
  }

  :global(.linen) {
    --ph-bg: #e8ddcf;
    --ph-circle: #f6efe6;
    --ph-corner: #c9beb2;
    --ph-square: #faf5ed;
    --ph-line: rgb(17 17 17 / 58%);
  }

  :global(.mint) {
    --ph-bg: #c6eadc;
    --ph-circle: #e9f6e6;
    --ph-corner: #a9cdbf;
    --ph-square: #e1f5ee;
    --ph-line: rgb(17 17 17 / 32%);
  }

  :global(.sky) {
    --ph-bg: #c7e1f2;
    --ph-circle: #e6f3fb;
    --ph-corner: #d4b9c8;
    --ph-square: #e4f3f8;
    --ph-line: rgb(17 17 17 / 62%);
  }

  :global(.lilac) {
    --ph-bg: #d9cff1;
    --ph-circle: #eee8fa;
    --ph-corner: #dcb0c5;
    --ph-square: #eee8fb;
    --ph-line: rgb(17 17 17 / 52%);
  }

  :global(.lemon) {
    --ph-bg: #f7e9a1;
    --ph-circle: #fff8c8;
    --ph-corner: #f5bf86;
    --ph-square: #fff7d7;
    --ph-line: rgb(17 17 17 / 22%);
  }

  :global(.circle-large),
  :global(.circle-corner),
  :global(.accent-mark),
  :global(.soft-square),
  :global(.stripe) {
    position: absolute;
    display: block;
  }

  :global(.circle-large) {
    left: -24%;
    bottom: -7%;
    width: 78%;
    aspect-ratio: 1;
    border-radius: var(--radius-pill);
    background: var(--ph-circle);
    opacity: 0.86;
  }

  :global(.circle-corner) {
    right: -18%;
    top: -10%;
    width: 46%;
    aspect-ratio: 1;
    border-radius: var(--radius-pill);
    background: var(--ph-corner);
    opacity: 0.86;
  }

  :global(.accent-mark) {
    left: 13%;
    top: 14%;
    width: 20%;
    max-width: 42px;
    aspect-ratio: 1;
    border-radius: var(--radius-pill);
    background: var(--theme-current-accent);
  }

  :global(.soft-square) {
    left: 14%;
    top: 11%;
    width: 32%;
    aspect-ratio: 1;
    border-radius: 20px;
    background: var(--ph-square);
    opacity: 0;
  }

  :global(.stripe) {
    left: 10%;
    bottom: 14%;
    width: 36%;
    height: 8%;
    border-radius: var(--radius-pill);
    background: var(--ph-line);
  }

  :global(.stripe-two) {
    display: none;
  }

  @media (max-width: 1120px) {
    .photo-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }
  }

  @media (max-width: 900px) {
    .album-hero {
      display: block;
      margin-bottom: 42px;
    }

    .hero-content .page-title {
      display: block;
      margin: 0 0 16px;
    }

    .hero-content .lead {
      display: block;
    }

    .actions {
      display: none;
    }

    .photo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }
  }

  @media (max-width: 640px) {
    .detail-page {
      padding: 29px 0 0;
    }

    .breadcrumb {
      margin-bottom: 13px;
      font-size: 15px;
    }

    .breadcrumb strong {
      display: none;
    }

    .hero-content .page-title {
      margin: 0 0 9px;
      font-size: 38px;
    }

    .hero-content .lead {
      font-size: 18px;
    }

    .meta-chips {
      margin-top: 20px;
    }

    .photos-toolbar {
      margin-bottom: 18px;
      padding: 0;
      border: 0;
      background: transparent;
    }

    .photos-toolbar h2 {
      font-size: 25px;
    }

    .toolbar-chips {
      display: none;
    }

    .photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      padding-bottom: 24px;
    }
  }
</style>
