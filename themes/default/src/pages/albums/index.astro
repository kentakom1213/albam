---
import Layout from "../../components/Layout.astro";
import { getThemeConfig } from "../../lib/theme-config";

const theme = getThemeConfig();
---

<Layout title={`${theme.siteTitle} | Album`}>
  <main
    class="page-shell detail-page"
    data-site-title={theme.siteTitle}
    style={`--photo-grid-columns: ${theme.layout.photoGridColumns}; --photo-grid-columns-tablet: ${theme.layout.photoGridColumnsTablet}; --photo-grid-columns-mobile: ${theme.layout.photoGridColumnsMobile};`}
  >
    <nav class="breadcrumb" id="album-breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Albums</a>
      <span class="separator" aria-hidden="true">/</span>
      <span aria-current="page">Loading</span>
    </nav>

    <section class="album-hero" aria-labelledby="album-title">
      <div class="hero-content">
        <h1 id="album-title" class="page-title">Loading</h1>
        <p class="lead" id="album-description"></p>
      </div>

      <div class="actions">
        <button class="button primary" type="button">Share</button>
        <button class="help-button" type="button" aria-label="Help">?</button>
      </div>
    </section>

    <div class="album-controls">
      <div class="meta-chips" id="meta-chips" aria-label="Album metadata"></div>
      <div class="toolbar-chips" aria-label="Photo filters">
        <span class="chip active small">All</span>
        <span class="chip small">Favorites</span>
        <span class="chip small">Newest</span>
      </div>
    </div>

    <section class="photos-section" aria-label="Photos">
      <div class="photo-grid" id="photo-grid">
        <div class="photo-card loading-photo-card" aria-label="Loading photos">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
        <div class="photo-card loading-photo-card" aria-hidden="true">
          <div class="photo-image loading-image">
            <span class="loading-circle large"></span>
            <span class="loading-circle small"></span>
            <span class="loading-mark"></span>
          </div>
        </div>
      </div>

      <div class="pagination-actions">
        <button class="button" id="load-more-photos" type="button" hidden>Load more</button>
      </div>
    </section>

    <div class="photo-modal" id="photo-modal" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
      <button class="modal-backdrop" type="button" data-modal-close aria-label="Close photo viewer"></button>
      <figure class="modal-frame">
        <button class="modal-close" type="button" data-modal-close aria-label="Close photo viewer">×</button>
        <img id="modal-image" alt="" />
        <figcaption id="modal-caption"></figcaption>
      </figure>
    </div>
  </main>
</Layout>

<script>
  import { formatCompactDate, formatCompactMonth, getAlbum, getAlbumPhotosWithPagination, getPhoto } from "../../lib/api";
  import type { Album, Breadcrumb, Photo } from "../../lib/api";

  const tones = ["peach", "linen", "mint", "sky", "lilac", "lemon"] as const;
  const siteTitle =
    document.querySelector<HTMLElement>(".detail-page")?.dataset.siteTitle ?? "albam";
  const photoModal = document.querySelector<HTMLElement>("#photo-modal");
  const modalImage = document.querySelector<HTMLImageElement>("#modal-image");
  const modalCaption = document.querySelector<HTMLElement>("#modal-caption");
  const loadMorePhotosButton = document.querySelector<HTMLButtonElement>("#load-more-photos");
  let loadedPhotoCount = 0;
  let hasMorePhotos = false;

  function escapeHTML(value: string) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return entities[char];
    });
  }

  function currentAlbumId() {
    const parts = window.location.pathname.split("/").filter(Boolean);
    return parts[0] === "albums" ? decodeURIComponent(parts[1] ?? "") : "";
  }

  function currentPhotoId() {
    const parts = window.location.pathname.split("/").filter(Boolean);
    return parts[0] === "albums" && parts[2] === "photos" ? decodeURIComponent(parts[3] ?? "") : "";
  }

  function albumPath(albumId: string) {
    return `/albums/${encodeURIComponent(albumId)}/`;
  }

  function photoPath(albumId: string, photoId: string) {
    return `${albumPath(albumId)}photos/${encodeURIComponent(photoId)}/`;
  }

  function imageHTML(src: string | undefined, tone: Album["tone"], alt: string, collage = false) {
    if (src) {
      return `<img class="image" src="${escapeHTML(src)}" alt="${escapeHTML(alt)}" loading="lazy" />`;
    }

    return `
      <div class="placeholder ${tone ?? "peach"} ${collage ? "collage" : ""}" role="img" aria-label="${escapeHTML(alt)}">
        <span class="circle-large"></span>
        <span class="circle-corner"></span>
        <span class="accent-mark"></span>
        <span class="soft-square"></span>
        <span class="stripe stripe-one"></span>
        <span class="stripe stripe-two"></span>
      </div>
    `;
  }

  function photoCard(photo: Photo, index: number) {
    const tone = photo.tone ?? tones[index % tones.length];
    const originalSrc = photo.originalSrc ?? photo.previewSrc ?? photo.src ?? "";

    return `
      <button
        class="photo-card"
        type="button"
        data-photo-id="${escapeHTML(photo.id)}"
        data-original-src="${escapeHTML(originalSrc)}"
        data-preview-src="${escapeHTML(photo.previewSrc ?? photo.src ?? "")}"
        data-title="${escapeHTML(photo.title)}"
      >
        <div class="photo-image">
          ${imageHTML(photo.src, tone, photo.title)}
        </div>
      </button>
    `;
  }

  function setText(selector: string, value: string) {
    const element = document.querySelector<HTMLElement>(selector);
    if (element) {
      element.textContent = value;
    }
  }

  function breadcrumbItemHTML(item: Breadcrumb, isCurrent: boolean) {
    const title = escapeHTML(item.title);

    if (isCurrent) {
      return `<span aria-current="page">${title}</span>`;
    }

    return `<a href="${escapeHTML(item.href)}">${title}</a>`;
  }

  function renderBreadcrumbs(album: Album) {
    const breadcrumbs = document.querySelector<HTMLElement>("#album-breadcrumbs");
    if (!breadcrumbs) {
      return;
    }

    const items = album.breadcrumbs.length
      ? album.breadcrumbs
      : [{ id: album.id, title: album.title, path: album.id, href: `/albums/${album.id}/` }];

    breadcrumbs.innerHTML = [
      `<a href="/">Albums</a>`,
      ...items.flatMap((item, index) => [
        `<span class="separator" aria-hidden="true">/</span>`,
        breadcrumbItemHTML(item, index === items.length - 1),
      ]),
    ].join("");
  }

  async function renderAlbum() {
    const albumId = currentAlbumId();
    const photoGrid = document.querySelector<HTMLElement>("#photo-grid");

    if (!albumId || !photoGrid) {
      if (photoGrid) {
        photoGrid.innerHTML = `<p class="load-state">Album not found.</p>`;
      }
      return;
    }

    try {
      const [album, photosResult] = await Promise.all([
        getAlbum(albumId),
        getAlbumPhotosWithPagination(albumId),
      ]);
      const { photos, pagination } = photosResult;
      loadedPhotoCount = photos.length;
      hasMorePhotos = pagination.has_next;
      const visibleDate = formatCompactDate(album.createdAt);
      const shortDate = formatCompactMonth(album.createdAt);

      document.title = `${siteTitle} | ${album.title}`;
      renderBreadcrumbs(album);
      setText("#album-title", album.title);
      setText("#album-description", album.description);

      const metaChips = document.querySelector<HTMLElement>("#meta-chips");

      if (metaChips) {
        metaChips.style.setProperty("--short-date", `"${shortDate}"`);
        metaChips.innerHTML = `
          <span class="chip active">${pagination.total.toLocaleString("en-US")} photos</span>
          <span class="chip">${escapeHTML(visibleDate)}</span>
        `;
      }

      photoGrid.innerHTML = photos.length
        ? photos.map(photoCard).join("")
        : `<p class="load-state">No photos indexed yet.</p>`;
      updateLoadMorePhotosButton();

      openDirectLinkedPhoto();
    } catch (error) {
      console.error(error);
      photoGrid.innerHTML = `<p class="load-state">Failed to load album.</p>`;
    }
  }

  function openPhotoModal(src: string, fallbackSrc: string, title: string, photoId = "", updateURL = false) {
    if (!photoModal || !modalImage || !modalCaption || !src) {
      return;
    }

    if (updateURL && photoId) {
      const albumId = currentAlbumId();
      if (albumId) {
        window.history.pushState({ photoId }, "", photoPath(albumId, photoId));
      }
    }

    modalImage.src = src;
    modalImage.alt = title;
    modalImage.dataset.fallbackSrc = fallbackSrc;
    modalCaption.textContent = title;
    photoModal.hidden = false;
    document.body.classList.add("modal-open");
  }

  function closePhotoModal(updateURL = true) {
    if (!photoModal || !modalImage || !modalCaption) {
      return;
    }

    if (updateURL && currentPhotoId()) {
      const albumId = currentAlbumId();
      if (albumId) {
        window.history.pushState({}, "", albumPath(albumId));
      }
    }

    photoModal.hidden = true;
    modalImage.removeAttribute("src");
    modalImage.removeAttribute("data-fallback-src");
    modalImage.alt = "";
    modalCaption.textContent = "";
    document.body.classList.remove("modal-open");
  }

  function updateLoadMorePhotosButton() {
    if (!loadMorePhotosButton) {
      return;
    }

    loadMorePhotosButton.hidden = !hasMorePhotos;
    loadMorePhotosButton.disabled = false;
    loadMorePhotosButton.textContent = "Load more";
  }

  function loadingButtonHTML(label: string) {
    return `
      <span>${label}</span>
      <span class="button-loading-dots" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    `;
  }

  async function loadMorePhotos() {
    const albumId = currentAlbumId();
    const photoGrid = document.querySelector<HTMLElement>("#photo-grid");
    if (!albumId || !photoGrid || !loadMorePhotosButton || !hasMorePhotos) {
      return;
    }

    loadMorePhotosButton.disabled = true;
    loadMorePhotosButton.innerHTML = loadingButtonHTML("Loading");

    try {
      const { photos, pagination } = await getAlbumPhotosWithPagination(albumId, {
        offset: loadedPhotoCount,
      });
      photoGrid.insertAdjacentHTML("beforeend", photos.map(photoCard).join(""));
      loadedPhotoCount += photos.length;
      hasMorePhotos = pagination.has_next;
      updateLoadMorePhotosButton();
    } catch (error) {
      console.error(error);
      loadMorePhotosButton.disabled = false;
      loadMorePhotosButton.textContent = "Load more";
    }
  }

  async function openDirectLinkedPhoto() {
    const photoId = currentPhotoId();
    if (!photoId) {
      return;
    }

    try {
      const photo = await getPhoto(photoId);
      openPhotoModal(
        photo.originalSrc ?? photo.previewSrc ?? photo.src ?? "",
        photo.previewSrc ?? photo.src ?? "",
        photo.title,
      );
    } catch (error) {
      console.error(error);
    }
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    const closeButton = target.closest("[data-modal-close]");
    if (closeButton) {
      closePhotoModal();
      return;
    }

    const photoCard = target.closest<HTMLElement>(".photo-card");
    if (!photoCard) {
      return;
    }

    openPhotoModal(
      photoCard.dataset.originalSrc ?? "",
      photoCard.dataset.previewSrc ?? "",
      photoCard.dataset.title ?? "Photo",
      photoCard.dataset.photoId ?? "",
      true,
    );
  });

  loadMorePhotosButton?.addEventListener("click", loadMorePhotos);

  window.addEventListener("popstate", () => {
    if (currentPhotoId()) {
      openDirectLinkedPhoto();
      return;
    }

    closePhotoModal(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && photoModal && !photoModal.hidden) {
      closePhotoModal();
    }
  });

  modalImage?.addEventListener("error", () => {
    const fallbackSrc = modalImage.dataset.fallbackSrc;
    if (fallbackSrc && modalImage.src !== fallbackSrc) {
      modalImage.src = fallbackSrc;
    }
  });

  renderAlbum();
</script>

<style>
  .detail-page {
    padding: 44px 0 110px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 48px;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--theme-text);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--theme-text);
  }

  .album-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: start;
    margin-bottom: 38px;
  }

  .hero-content {
    min-height: 0;
  }

  .hero-content .page-title {
    display: inline-block;
    margin: 0 42px 0 0;
    font-size: clamp(52px, 5.8vw, 70px);
    vertical-align: middle;
  }

  .hero-content .lead {
    display: inline;
    color: var(--theme-muted);
    font-size: 23px;
    font-weight: 600;
    line-height: 1.7;
  }

  .album-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 32px;
  }

  .meta-chips,
  .actions,
  .toolbar-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .actions {
    align-items: center;
    justify-content: flex-end;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(var(--photo-grid-columns), minmax(0, 1fr));
    gap: 8px 10px;
  }

  .load-state {
    grid-column: 1 / -1;
    margin: 0;
    color: var(--theme-muted);
    font-size: 16px;
    font-weight: 600;
  }

  :global(.button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 24px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 14px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.button.primary) {
    border-color: var(--theme-text);
    background: var(--theme-text);
    color: var(--theme-surface);
  }

  .pagination-actions {
    display: flex;
    justify-content: center;
    margin-top: 28px;
  }

  .pagination-actions:has([hidden]) {
    display: none;
  }

  .button[disabled] {
    cursor: progress;
    opacity: 0.78;
  }

  :global(.button-loading-dots) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 10px;
  }

  :global(.button-loading-dots span) {
    width: 5px;
    height: 5px;
    border-radius: var(--radius-pill);
    background: var(--theme-current-accent);
    animation: loading-dot 0.9s ease-in-out infinite;
  }

  :global(.button-loading-dots span:nth-child(2)) {
    animation-delay: 0.12s;
  }

  :global(.button-loading-dots span:nth-child(3)) {
    animation-delay: 0.24s;
  }

  .help-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
  }

  :global(.chip) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0 17px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-muted);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.chip.active) {
    border-color: var(--theme-current-accent);
    background: var(--theme-current-accent-soft);
    color: var(--theme-text);
  }

  :global(.chip.small) {
    min-height: 30px;
    padding: 0 14px;
    font-size: 13px;
  }

  :global(.image),
  :global(.placeholder) {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 12px;
  }

  :global(.image) {
    object-fit: cover;
    color: transparent;
    font-size: 0;
    background:
      linear-gradient(100deg, transparent 0%, rgb(255 255 255 / 52%) 45%, transparent 76%),
      var(--theme-current-accent-soft);
    background-size: 220% 100%, 100% 100%;
    animation: image-loading-sheen 1.8s ease-in-out infinite;
  }

  :global(.placeholder) {
    position: relative;
    background: var(--ph-bg);
  }

  :global(.photo-card) {
    display: block;
    width: 100%;
    padding: 8px;
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-card);
    background: var(--theme-surface);
    color: inherit;
    overflow: hidden;
    text-align: left;
  }

  :global(.photo-card:focus-visible) {
    outline: 2px solid var(--theme-current-accent);
    outline-offset: 4px;
  }

  :global(.loading-photo-card) {
    pointer-events: none;
  }

  :global(.photo-image) {
    aspect-ratio: 1;
  }

  :global(.loading-image) {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: var(--theme-current-accent-soft);
    animation: loading-surface 1.45s ease-in-out infinite;
  }

  :global(.loading-image)::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, transparent 0%, rgb(255 255 255 / 52%) 45%, transparent 76%);
    transform: translateX(-120%);
    animation: loading-sheen 1.8s ease-in-out infinite;
  }

  :global(.loading-circle),
  :global(.loading-mark) {
    position: absolute;
    display: block;
    border-radius: var(--radius-pill);
  }

  :global(.loading-circle.large) {
    left: -20%;
    bottom: -12%;
    width: 72%;
    aspect-ratio: 1;
    background: rgb(255 255 255 / 62%);
  }

  :global(.loading-circle.small) {
    right: -10%;
    top: -8%;
    width: 38%;
    aspect-ratio: 1;
    background: rgb(255 98 90 / 18%);
  }

  :global(.loading-mark) {
    left: 14%;
    top: 14%;
    width: 17%;
    aspect-ratio: 1;
    background: var(--theme-current-accent);
    animation: loading-pop 1.45s ease-in-out infinite;
  }

  .photo-modal[hidden] {
    display: none;
  }

  .photo-modal {
    position: fixed;
    inset: 0;
    z-index: 20;
    display: grid;
    place-items: center;
    padding: 42px;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(17 17 17 / 78%);
  }

  .modal-frame {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    max-width: min(100%, 1240px);
    max-height: 100%;
    margin: 0;
  }

  .modal-frame img {
    max-width: 100%;
    max-height: calc(100vh - 128px);
    border-radius: 12px;
    object-fit: contain;
    box-shadow: 0 24px 80px rgb(0 0 0 / 34%);
  }

  .modal-close {
    position: absolute;
    right: -18px;
    top: -18px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgb(255 255 255 / 30%);
    border-radius: var(--radius-pill);
    background: var(--theme-surface);
    color: var(--theme-text);
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
  }

  #modal-caption {
    margin-top: 14px;
    color: rgb(255 255 255 / 78%);
    font-size: 14px;
    font-weight: 600;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  @keyframes loading-sheen {
    to {
      transform: translateX(120%);
    }
  }

  @keyframes image-loading-sheen {
    from {
      background-position: -120% 0, 0 0;
    }

    to {
      background-position: 120% 0, 0 0;
    }
  }

  @keyframes loading-surface {
    0%,
    100% {
      opacity: 0.62;
    }

    50% {
      opacity: 1;
    }
  }

  @keyframes loading-pop {
    0%,
    100% {
      transform: scale(0.88);
    }

    50% {
      transform: scale(1);
    }
  }

  @keyframes loading-dot {
    0%,
    80%,
    100% {
      transform: translateY(0);
      opacity: 0.42;
    }

    40% {
      transform: translateY(-3px);
      opacity: 1;
    }
  }

  :global(.peach) {
    --ph-bg: #f9cdb9;
    --ph-circle: #fde6dc;
    --ph-corner: #f7a99e;
    --ph-square: #fff5ee;
    --ph-line: rgb(17 17 17 / 62%);
  }

  :global(.linen) {
    --ph-bg: #e8ddcf;
    --ph-circle: #f6efe6;
    --ph-corner: #c9beb2;
    --ph-square: #faf5ed;
    --ph-line: rgb(17 17 17 / 58%);
  }

  :global(.mint) {
    --ph-bg: #c6eadc;
    --ph-circle: #e9f6e6;
    --ph-corner: #a9cdbf;
    --ph-square: #e1f5ee;
    --ph-line: rgb(17 17 17 / 32%);
  }

  :global(.sky) {
    --ph-bg: #c7e1f2;
    --ph-circle: #e6f3fb;
    --ph-corner: #d4b9c8;
    --ph-square: #e4f3f8;
    --ph-line: rgb(17 17 17 / 62%);
  }

  :global(.lilac) {
    --ph-bg: #d9cff1;
    --ph-circle: #eee8fa;
    --ph-corner: #dcb0c5;
    --ph-square: #eee8fb;
